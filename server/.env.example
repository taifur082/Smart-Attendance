# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/attendance_db

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# API Authentication
API_KEY=your-api-key-here

# SMS Gateway Configuration
# Use custom for your gateway (api_key, senderid, msg, numbers format)
SMS_PROVIDER=custom
SMS_GATEWAY_URL=https://sms.mygiftcard.top/api/v1/smsapi
SMS_API_KEY=$2y$12$VLF/w4Natk1wv6U/owVb/.rPkyfs2T4G2heOQOaK0YK2hGsT9m.XW
SMS_SENDER_ID=8809612442476

# Twilio (when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Configuration (Green API) - https://green-api.com
GREEN_API_ID_INSTANCE=your-instance-id
GREEN_API_API_TOKEN_INSTANCE=your-api-token

# Which channel to use for attendance notifications: whatsapp | sms
NOTIFICATION_CHANNEL=whatsapp
# When using WhatsApp, fall back to SMS if WhatsApp fails or student has no parent_whatsapp
NOTIFICATION_FALLBACK_SMS=true
NOTIFICATION_COOLDOWN_HOURS=1
